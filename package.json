{
  "name": "d4l-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "knip": "knip",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run type-check && npm run knip",
    "prepare": "husky install",
    "test": "jest",
    "test:e2e": "playwright test --host 0.0.0.0",
    "test:e2e:show": "playwright show-report --host 0.0.0.0",
    "test:all": "npm run test && npm run test:e2e",
    "test:ui": "playwright test --ui --ui-host 0.0.0.0 --ui-port 9323",
    "db:studio": "prisma studio --browser none",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:deploy": "prisma deploy migrate",
    "db:push": "prisma db push",
    "worker:scheduler": "tsx --tsconfig tsconfig.scripts.json scripts/scheduler.ts",
    "worker:mail": "tsx --tsconfig tsconfig.scripts.json scripts/mail-worker.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@d4l/collect-lib": "^1.33.2",
    "@prisma/client": "^7.5.0",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.8.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.2",
    "nodemailer": "^7.0.13",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shadcn": "^4.3.1",
    "tailwind-merge": "^3.5.0",
    "temporal-polyfill": "^0.3.2",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.58.2",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fhir": "^0.0.42",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "msw": "^2.12.10",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
